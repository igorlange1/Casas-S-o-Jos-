RewriteEngine On
RewriteBase /

# Forçar HTTPS (Opcional, mas recomendado para sites modernos)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Se o arquivo físico existe, carrega ele direto (ex: imagens, scripts, receber.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Se o usuário acessar /modelos, o servidor busca internamente modelos.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Redirecionar /pagina.html para /pagina (para limpar a barra de endereços se alguém digitar com .html)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /+(.*)\.html\ HTTP/ [NC]
RewriteRule ^(.+)\.html$ /$1 [L,R=301]
